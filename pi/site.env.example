# Site configuration for the Pi services — the env-var mirror of
# js/site-config.js. Copy to /etc/kanp/site.env and edit when pointing the
# tracker at a different airport; every service reads it via EnvironmentFile.
# Anything unset falls back to the defaults baked into pi/*.py (KANP values).

# --- collector.py ---
KANP_LAT=38.9422
KANP_LON=-76.5684
KANP_RADIUS_NM=60
# "airplanes" = public ADS-B API feeds; or a local receiver URL, e.g.
# http://127.0.0.1/skyaware/data/aircraft.json
#KANP_SOURCE=airplanes
#KANP_POLL_SECONDS=3
#KANP_RETENTION_DAYS=365
#KANP_MAX_DB_MB=8000

# --- server.py ---
#KANP_PORT=8787

# --- exporter.py ---
#KANP_EXPORT_PUSH=1
#KANP_SIMPLIFY_NM=0.03

# --- atc.py (LiveATC recorder + whisper transcripts) ---
# Feeds: semicolon list of  mount|label|frequency  (mount = LiveATC stream
# name, e.g. https://d.liveatc.net/kbwi_es_app_124550). Defaults baked into
# atc.py are the three Potomac feeds around KANP.
#KANP_ATC_FEEDS=kbwi_es_app_124550|Potomac Approach GRACO|124.550;kbwi_es_app_125525|Potomac Approach BELAY|125.525;kbwi_es_final|Potomac BWI Final|119.0/119.7
#KANP_ATC_DIR=/var/lib/kanp/atc
#KANP_ATC_WHISPER_BIN=/opt/whisper.cpp/build/bin/whisper-cli
#KANP_ATC_WHISPER_MODEL=/opt/whisper.cpp/models/ggml-base.en.bin
#KANP_ATC_WHISPER_THREADS=3
#KANP_ATC_RETENTION_DAYS=14
# Squelch: raise OPEN_RMS if noise triggers recordings, lower if it clips
# quiet transmissions.
#KANP_ATC_OPEN_RMS=700
#KANP_ATC_CLOSE_RMS=400
